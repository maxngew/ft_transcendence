# Copy this file to .env and fill in the values before running docker compose up.
# .env is gitignored and must never be committed.

# PostgreSQL credentials
POSTGRES_DB=transcendence
POSTGRES_USER=transcendence
POSTGRES_PASSWORD=change_me_please

# Use localhost when running Prisma or the backend directly on your host.
DATABASE_URL=postgresql://transcendence:change_me_please@localhost:5432/transcendence?schema=public

# Better Auth
BETTER_AUTH_SECRET=change_me_to_a_32_byte_random_secret
BETTER_AUTH_URL=https://localhost:8443
# LAN testing example, replace <LAN_IP> with this machine's current network IP:
# CADDY_SITE_ADDRESS="https://localhost:8443, https://<LAN_IP>:8443"
# CADDY_DEFAULT_SNI=<LAN_IP>
# BETTER_AUTH_URL=https://<LAN_IP>:8443
# BETTER_AUTH_TRUSTED_ORIGINS=https://localhost:8443,https://<LAN_IP>:8443
# Auth email delivery modes:
# - console: print password-reset links to the server console for local development
# - resend-smtp: send password-reset emails through Resend SMTP
# - disabled: reject auth email delivery
AUTH_EMAIL_MODE=console

# Resend SMTP auth emails (required when AUTH_EMAIL_MODE=resend-smtp)
# Create an API key in Resend and verify the domain used in RESEND_FROM_EMAIL.
RESEND_API_KEY=
RESEND_FROM_EMAIL="42 Transcendence Gomoku <onboarding@resend.dev>"
RESEND_REPLY_TO_EMAIL=
# Optional Resend SMTP overrides. Defaults match Resend's documented SMTP settings.
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=465
# RESEND_SMTP_USER=resend
# RESEND_SMTP_SECURE=true

# OAuth 2.0 providers (optional)
# GitHub callback URL: http://localhost:3000/api/auth/callback/github
# Docker/Caddy callback URL: https://localhost:8443/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google callback URL: http://localhost:3000/api/auth/callback/google
# Docker/Caddy callback URL: https://localhost:8443/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional direct-host Socket.IO settings.
# Leave these unset when using the same-origin Caddy entrypoint.
# SOCKET_PUBLIC_URL=http://localhost:3001
# SOCKET_CORS_ORIGIN=http://localhost:3000,https://localhost:8443
# LAN testing with Caddy:
# Leave SOCKET_PUBLIC_URL unset so each browser uses its current origin.
# SOCKET_CORS_ORIGIN=https://localhost:8443,https://<LAN_IP>:8443
# REALTIME_INTERNAL_URL=http://localhost:3001/internal/game-update
# REALTIME_FRIENDSHIP_INTERNAL_URL=http://localhost:3001/internal/friendship-update
# REALTIME_INTERNAL_SECRET=change_me_to_a_shared_internal_secret

# Optional matchmaking lifecycle timeouts.
# MATCHMAKING_WAITING_TIMEOUT_MS=600000
# MATCH_IN_PROGRESS_ABANDONED_TIMEOUT_MS=1800000
